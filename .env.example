# ── LLM ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OLLAMA_MODEL=mistral:7b
OLLAMA_BASE_URL=http://localhost:11434

# ── LinkedIn ──────────────────────────────────────────────────────────────────
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=yourpassword

# ── Naukri ────────────────────────────────────────────────────────────────────
NAUKRI_EMAIL=you@example.com
NAUKRI_PASSWORD=yourpassword

# ── Captcha (optional) ────────────────────────────────────────────────────────
TWOCAPTCHA_API_KEY=

# ── Match thresholds ──────────────────────────────────────────────────────────
# Full-time jobs: only apply if score >= this
MATCH_THRESHOLD=85
# Internships: lower bar — experience is NOT expected for interns
INTERNSHIP_MATCH_THRESHOLD=70

# ── Search: full-time jobs ────────────────────────────────────────────────────
SEARCH_KEYWORDS=machine learning engineer,NLP engineer,AI engineer,MLOps
SEARCH_LOCATION=India
MAX_LISTINGS_PER_RUN=20

# ── Search: internships (searched separately with internship-aware scoring) ───
INTERNSHIP_KEYWORDS=machine learning intern,NLP intern,AI intern,data science intern,deep learning intern

# ── Resume ────────────────────────────────────────────────────────────────────
RESUME_FORMAT=docx

# ── Personal info (pre-fills forms automatically) ─────────────────────────────
PHONE=+91XXXXXXXXXX
CURRENT_LOCATION=Bangalore, India
NOTICE_PERIOD=Immediate
CURRENT_CTC=0 LPA
EXPECTED_CTC=Stipend / As per company norms
TOTAL_EXPERIENCE_YEARS=0

# ── Browser ───────────────────────────────────────────────────────────────────
HEADLESS=false
SLOW_MO=50
